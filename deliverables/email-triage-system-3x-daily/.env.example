# Email Triage System Configuration

# Gmail API Configuration
# Download service account JSON from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_KEY_FILE=./service-account.json

# Slack Configuration (for urgent alerts)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_USER_ID=U12345678  # Chip's user ID for DMs

# Optional: Database Configuration
# Database backend: sqlite, postgres, or json-file
DATABASE_TYPE=json-file
DATABASE_PATH=./triage.db

# Optional: Response Drafting
# Enable response draft generation and approval queue
ENABLE_DRAFT_RESPONSES=true

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
