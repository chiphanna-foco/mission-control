{
  "name": "email-triage-system",
  "version": "1.0.0",
  "description": "3x Daily Email Triage for Mission Control - Classification, Action Extraction, Urgency Detection",
  "main": "scripts/email-triage.js",
  "scripts": {
    "triage": "node scripts/email-triage.js",
    "triage:test": "node scripts/email-triage.js --test",
    "dev": "ts-node scripts/email-triage.js",
    "build": "tsc",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest",
    "install-launchd": "bash scripts/install-launchd.sh",
    "logs:morning": "tail -f logs/morning.log logs/morning-error.log",
    "logs:noon": "tail -f logs/noon.log logs/noon-error.log",
    "logs:evening": "tail -f logs/evening.log logs/evening-error.log",
    "launchctl:status": "launchctl list | grep email-triage",
    "launchctl:morning:start": "launchctl start com.mission-control.email-triage-morning",
    "launchctl:noon:start": "launchctl start com.mission-control.email-triage-noon",
    "launchctl:evening:start": "launchctl start com.mission-control.email-triage-evening"
  },
  "keywords": [
    "email",
    "gmail",
    "triage",
    "classification",
    "automation",
    "mission-control"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "googleapis": "^118.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
