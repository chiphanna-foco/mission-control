# Approval Queue System Configuration

# ==============================================
# Queue Storage
# ==============================================

# Root directory for approval queue storage
# Directory structure created automatically:
#   /data/approval-queue/pending/    - Items awaiting review
#   /data/approval-queue/approved/   - Approved items
#   /data/approval-queue/rejected/   - Rejected items
#   /data/approval-queue/audit.log   - Audit trail
# 
# Default: /data/approval-queue
QUEUE_ROOT=/data/approval-queue

# ==============================================
# Slack Integration (Optional)
# ==============================================

# Slack bot token with chat:write permission
# Get from: https://api.slack.com/apps
# Token format: xoxb-...
# Required for Slack notifications to work
SLACK_BOT_TOKEN=

# User ID to receive approval notifications
# Get from: Right-click profile in Slack → Copy user ID
# Format: U1234567890
SLACK_APPROVER_USER_ID=

# ==============================================
# Email Service Integration (Optional)
# ==============================================

# SendGrid API key for sending email approvals
# Get from: https://sendgrid.com/
SENDGRID_TOKEN=

# Email service endpoint (for custom implementations)
EMAIL_SERVICE_ENDPOINT=https://api.example.com/send

# ==============================================
# Social Media Integrations (Optional)
# ==============================================

# Twitter/X API
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Instagram API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ==============================================
# Blog/CMS Integration (Optional)
# ==============================================

# WordPress API
WORDPRESS_SITE_URL=https://blog.example.com
WORDPRESS_TOKEN=
WORDPRESS_USERNAME=
WORDPRESS_PASSWORD=

# Medium API
MEDIUM_ACCESS_TOKEN=

# ==============================================
# Database (Future - for scaling beyond files)
# ==============================================

# When migrating from file-based to database:
DATABASE_URL=postgresql://user:password@localhost:5432/approval_queue
DATABASE_TYPE=postgresql

# ==============================================
# Logging & Monitoring (Optional)
# ==============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable detailed logging
DEBUG=

# Sentry error tracking
SENTRY_DSN=

# ==============================================
# Application Settings
# ==============================================

# Node environment
NODE_ENV=development

# API base URL
API_BASE_URL=http://localhost:3000

# Approval timeout (minutes) - how long to wait before auto-rejecting
APPROVAL_TIMEOUT_MINUTES=240

# Page size for pagination
DEFAULT_PAGE_SIZE=15
MAX_PAGE_SIZE=100

# ==============================================
# Authentication (Optional)
# ==============================================

# API key for webhook authenticity
APPROVAL_WEBHOOK_SECRET=

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ==============================================
# Feature Flags
# ==============================================

# Enable Slack notifications
ENABLE_SLACK_NOTIFICATIONS=true

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# Enable auto-execution after approval
ENABLE_AUTO_EXECUTION=false

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# ==============================================
# Development Settings (Remove in production)
# ==============================================

# Allow direct approval without login (dev only)
DEV_ALLOW_ANONYMOUS_APPROVAL=false

# Use mock/test approval responses
DEV_USE_MOCK_APPROVALS=false

# Sample data for testing
DEV_CREATE_SAMPLE_DATA=false
