{
  "name": "meeting-to-action-item-extractor",
  "version": "1.0.0",
  "description": "Extract action items from meeting transcripts with automatic tracking and overdue alerts",
  "type": "module",
  "main": "src/engine.js",
  "bin": {
    "extract-actions": "src/cli.js",
    "check-overdue": "src/monitor.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "monitor": "node src/monitor.js",
    "test": "node tests/extraction.test.js",
    "test:dates": "node tests/date-parsing.test.js",
    "test:overdue": "node tests/overdue.test.js",
    "test:all": "npm test && npm run test:dates && npm run test:overdue",
    "setup": "node src/setup.js",
    "extract": "node src/cli.js",
    "check": "node src/monitor.js --check",
    "alert": "node src/monitor.js --alert",
    "report": "node src/monitor.js --report"
  },
  "keywords": [
    "meetings",
    "action-items",
    "task-extraction",
    "ai",
    "automation",
    "mission-control"
  ],
  "author": "Chip Hanna",
  "license": "MIT",
  "dependencies": {
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3",
    "commander": "^11.0.0",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "chrono-node": "^2.6.4",
    "natural": "^6.7.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "@types/node": "^20.0.0"
  }
}
