{
  "name": "slack-approval-bot",
  "version": "1.0.0",
  "description": "Slack DM approval bot for Mission Control",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "sync": "ts-node scripts/sync-approval-status.ts",
    "sync:watch": "nodemon --exec 'npm run sync' --watch data",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@slack/web-api": "^6.9.0",
    "axios": "^1.6.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "querystring": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/querystring": "^0.2.2",
    "typescript": "^5.3.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
