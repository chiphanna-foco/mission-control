<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.missioncontrol.slack-approval-bot</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/env</string>
		<string>node</string>
		<string>/Users/REPLACE_USERNAME/Documents/Shared/projects/set-up-slack-dm-approval-bot/scripts/sync-approval-status.ts</string>
	</array>
	<key>StartInterval</key>
	<integer>300</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>EnvironmentVariables</key>
	<dict>
		<key>DATA_DIR</key>
		<string>/Users/REPLACE_USERNAME/Documents/Shared/projects/set-up-slack-dm-approval-bot/data</string>
		<key>DASHBOARD_WEBHOOK_URL</key>
		<string>http://localhost:3000/api/approval-queue/webhook</string>
		<key>NODE_ENV</key>
		<string>production</string>
	</dict>
	<key>StandardOutPath</key>
	<string>/var/log/slack-approval-bot.log</string>
	<key>StandardErrorPath</key>
	<string>/var/log/slack-approval-bot-error.log</string>
	<key>KeepAlive</key>
	<false/>
	<key>ProcessType</key>
	<string>Adaptive</string>
</dict>
</plist>
