# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# DO NOT commit .env file - use .env.example only
# ============================================

# Required for Railway deployment
NODE_ENV=production
DATABASE_URL=/data/mission-control.db

# Security
SESSION_SECRET=your-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here-min-32-chars
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# API Security
RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=https://mc.chip-hanna.com,https://chip-hanna.railway.app

# Magic Link Authentication
ALLOWED_EMAILS=email1@example.com,email2@example.com
NEXTAUTH_URL=https://your-domain.com

# Mailgun Email Configuration
MAILGUN_DOMAIN=sandbox123456.mailgun.org
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_FROM=noreply@your-domain.com

# Google Workspace Integration (optional for Railway)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-railway-domain/api/auth/callback/google

# Logging
LOG_LEVEL=info
LOG_FILE=/data/logs/mission-control.log

# Monitoring (optional)
SENTRY_DSN=https://your-sentry-dsn
DATADOG_API_KEY=your-datadog-key

# Backups (optional)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# Security Headers
STRICT_TRANSPORT_SECURITY_MAX_AGE=31536000
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.googleapis.com;

# Feature Flags
ENABLE_API_DOCS=false
ENABLE_DEBUG_ROUTES=false
