{
  "name": "mission-control",
  "runtime": "nodejs",
  "plan": "pro",
  "services": [
    {
      "name": "mission-control",
      "runtime": "nodejs",
      "startCommand": "npm run build && npm start"
    }
  ],
  "volumes": [
    {
      "name": "db-volume",
      "mountPath": "/data",
      "size": "1GB"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DATABASE_URL": "/data/mission-control.db",
    "LOG_LEVEL": "info"
  }
}
